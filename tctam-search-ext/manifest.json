{
  "manifest_version": 3,
  "name": "TC_tam Search",
  "version": "1.0",
  "description": "The extention makes the TC_tam Search new tab the standard homepage.",
  "author": "TC_tam",
  "chrome_url_overrides": {
    "newtab": "redirect.html"
  },
  "content_scripts": [
    {
      "matches": [
        "*://tctam.nl/*",
        "*://localhost/*",
        "*://127.0.0.1/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}